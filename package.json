{
  "name": "vue-os-simulator",
  "version": "1.0.0",
  "description": "Emulador de Sistema Operativo Móvil/Desktop con capacidades de hardware reales",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev:vue": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json && tsc -p electron/tsconfig.preload.json && electron .",
    "dev:daemon": "cd daemon && go run main.go",
    "dev": "vite",
    "build:vue": "vue-tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && tsc -p electron/tsconfig.preload.json",
    "build": "pnpm build:vue && pnpm build:electron"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "dexie": "^4.0.10",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^29.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.4.21",
    "vue-tsc": "^1.8.27"
  }
}
